generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id           String        @id @default(uuid())
  name         String
  slug         String?
  tenantId     String?
  doctors      Doctor[]
}

model Doctor {
  id           String        @id @default(uuid())
  name         String
  specialty    String
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
}

model Patient {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  phone        String        @unique
  medicalNotes String?       // NEW: AI Vision will save notes here
  appointments Appointment[]
}

model Appointment {
  id           String    @id @default(uuid())
  date         String
  time         String
  treatment    String
  value        Int
  status       String
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id])
  doctorId     String
  doctor       Doctor    @relation(fields: [doctorId], references: [id])
}